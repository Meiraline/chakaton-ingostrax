42\\u044C \\u0438\\u0445 \\u0447\\u0435\\u0440\\u0435\\u0437 \\u0438\\u0433\\u0440\\u0443.\"})]}),/*#__PURE__*/_jsx(\"div\",{className:\"landing-about__image-card\",children:/*#__PURE__*/_jsx(\"img\",{src:\"/png/glavnaia.png\",alt:\"\\u0418\\u043B\\u043B\\u044E\\u0441\\u0442\\u0440\\u0430\\u0446\\u0438\\u044F \\u043E \\u0441\\u0435\\u0440\\u0432\\u0438\\u0441\\u0435\"})})]}),/*#__PURE__*/_jsxs(\"div\",{className:\"landing-about__story\",children:[/*#__PURE__*/_jsx(\"div\",{className:\"landing-about__frame\",children:/*#__PURE__*/_jsx(\"img\",{src:\"/png/plaer_all.png\",alt:\"\\u0418\\u0433\\u0440\\u043E\\u0432\\u043E\\u0439 \\u043F\\u0435\\u0440\\u0441\\u043E\\u043D\\u0430\\u0436\"})}),/*#__PURE__*/_jsxs(\"div\",{className:\"landing-about__story-text\",children:[/*#__PURE__*/_jsx(\"p\",{children:\"\\u0418\\u0433\\u0440\\u043E\\u0432\\u0430\\u044F \\u0447\\u0430\\u0441\\u0442\\u044C \\u0434\\u0435\\u043B\\u0430\\u0435\\u0442 \\u043E\\u0431\\u0443\\u0447\\u0435\\u043D\\u0438\\u0435 \\u0436\\u0438\\u0432\\u044B\\u043C \\u0438 \\u0438\\u043D\\u0442\\u0435\\u0440\\u0430\\u043A\\u0442\\u0438\\u0432\\u043D\\u044B\\u043C. \\u0423 \\u0438\\u0433\\u0440\\u043E\\u043A\\u0430 \\u0435\\u0441\\u0442\\u044C \\u043F\\u0435\\u0440\\u0441\\u043E\\u043D\\u0430\\u0436 \\u0441\\u043E \\u0441\\u0432\\u043E\\u0438\\u043C\\u0438 \\u0440\\u0435\\u0441\\u0443\\u0440\\u0441\\u0430\\u043C\\u0438: \\u0434\\u0435\\u043D\\u044C\\u0433\\u0430\\u043C\\u0438, \\u0437\\u0434\\u043E\\u0440\\u043E\\u0432\\u044C\\u0435\\u043C, \\u0441\\u0447\\u0430\\u0441\\u0442\\u044C\\u0435\\u043C, \\u0438\\u043C\\u0443\\u0449\\u0435\\u0441\\u0442\\u0432\\u043E\\u043C \\u0438 \\u0441\\u0442\\u0440\\u0430\\u0445\\u043E\\u0432\\u044B\\u043C\\u0438 \\u043F\\u043E\\u043B\\u0438\\u0441\\u0430\\u043C\\u0438.\"}),/*#__PURE__*/_jsx(\"p\",{children:\"\\u041D\\u0430 \\u043A\\u0430\\u0436\\u0434\\u043E\\u043C \\u0445\\u043E\\u0434\\u0443 \\u0435\\u043C\\u0443 \\u0432\\u044B\\u043F\\u0430\\u0434\\u0430\\u044E\\u0442 \\u043D\\u0435\\u043E\\u0436\\u0438\\u0434\\u0430\\u043D\\u043D\\u044B\\u0435 \\u0441\\u043E\\u0431\\u044B\\u0442\\u0438\\u044F, \\u0445\\u043E\\u0440\\u043E\\u0448\\u0438\\u0435 \\u0438 \\u043F\\u043B\\u043E\\u0445\\u0438\\u0435, \\u0430 \\u0434\\u0430\\u043B\\u044C\\u0448\\u0435 \\u0432\\u0441\\u0451 \\u0437\\u0430\\u0432\\u0438\\u0441\\u0438\\u0442 \\u043E\\u0442 \\u0435\\u0433\\u043E \\u0440\\u0435\\u0448\\u0435\\u043D\\u0438\\u0439: \\u0438\\u0433\\u0440\\u043E\\u043A \\u043E\\u0431\\u0449\\u0430\\u0435\\u0442\\u0441\\u044F \\u0441 \\u0418\\u0418, \\u0432\\u044B\\u0431\\u0438\\u0440\\u0430\\u0435\\u0442, \\u043A\\u0430\\u043A \\u043F\\u043E\\u0441\\u0442\\u0443\\u043F\\u0438\\u0442\\u044C, \\u0438 \\u0432\\u0438\\u0434\\u0438\\u0442 \\u043F\\u043E\\u0441\\u043B\\u0435\\u0434\\u0441\\u0442\\u0432\\u0438\\u044F \\u0441\\u0432\\u043E\\u0438\\u0445 \\u0434\\u0435\\u0439\\u0441\\u0442\\u0432\\u0438\\u0439.\"}),/*#__PURE__*/_jsx(\"p\",{children:\"\\u0422\\u0430\\u043A \\u0438\\u0433\\u0440\\u043E\\u043A \\u043F\\u043E\\u0441\\u0442\\u0435\\u043F\\u0435\\u043D\\u043D\\u043E \\u043F\\u043E\\u043D\\u0438\\u043C\\u0430\\u0435\\u0442, \\u043A\\u0430\\u043A \\u0441\\u0442\\u0440\\u0430\\u0445\\u043E\\u0432\\u043A\\u0430 \\u043F\\u043E\\u043C\\u043E\\u0433\\u0430\\u0435\\u0442 \\u0441\\u043F\\u0440\\u0430\\u0432\\u043B\\u044F\\u0442\\u044C\\u0441\\u044F \\u0441 \\u0440\\u0438\\u0441\\u043A\\u0430\\u043C\\u0438 \\u0438 \\u043F\\u0440\\u0438\\u043D\\u0438\\u043C\\u0430\\u0442\\u044C \\u0440\\u0435\\u0448\\u0435\\u043D\\u0438\\u044F.\"})]})]}),/*#__PURE__*/_jsx(\"div\",{className:\"landing-features\",children:features.map(feature=>/*#__PURE__*/_jsxs(\"article\",{className:\"landing-feature\",children:[/*#__PURE__*/_jsx(\"h3\",{children:feature.title}),/*#__PURE__*/_jsx(\"p\",{children:feature.description})]},feature.title))})]});}export default LandingAboutSection;","map":{"version":3,"names":["React","jsx","_jsx","jsxs","_jsxs","features","title","description","LandingAboutSection","className","children","src","alt","map","feature"],"sources":["C:/My-Projact/chakaton-ingostrax/src/components/3_organism/LandingAboutSection.js"],"sourcesContent":["import React from 'react';\nimport './LandingAboutSection.css';\n\nconst features = [\n  {\n    title: 'Понятный сервис',\n    description: 'Детям 7-14 лет удобно понимать важные темы через игру и яркие персонажи.',\n  },\n  {\n    title: 'Страховки в игре',\n    description: 'Покупай страховки, изучай их характеристики и смотри, как они влияют на ход событий.',\n  },\n  {\n    title: 'Блог с примерами',\n    description: 'Короткие статьи объясняют виды страхования простым языком.',\n  },\n];\n\nfunction LandingAboutSection() {\n  return (\n    <section className=\"landing-about\">\n      <div className=\"landing-about__intro\">\n        <div className=\"landing-about__text\">\n          <h2>О сервисе</h2>\n          <p>\n            Этот сервис превращает знакомство со страхованием в понятное и увлекательное\n            приключение. На сайте посетитель не просто читает о том, зачем нужны разные\n            виды страховок, а учится понимать их через игру.\n          </p>\n        </div>\n\n        <div className=\"landing-about__image-card\">\n          <img src=\"/png/glavnaia.png\" alt=\"Иллюстрация о сервисе\" />\n        </div>\n      </div>\n\n      <div className=\"landing-about__story\">\n        <div className=\"landing-about__frame\">\n          <img src=\"/png/plaer_all.png\" alt=\"Игровой персонаж\" />\n        </div>\n\n        <div className=\"landing-about__story-text\">\n          <p>\n            Игровая часть делает обучение живым и интерактивным. У игрока есть персонаж\n            со своими ресурсами: деньгами, здоровьем, счастьем, имуществом и страховыми\n            полисами.\n          </p>\n          <p>\n            На каждом ходу ему выпадают неожиданные события, хорошие и плохие, а дальше\n            всё зависит от его решений: игрок общается с ИИ, выбирает, как поступить, и\n            видит последствия своих действий.\n          </p>\n          <p>\n            Так игрок постепенно понимает, как страховка помогает справляться с рисками и\n            принимать решения.\n          </p>\n        </div>\n      </div>\n\n      <div className=\"landing-features\">\n        {features.map((feature) => (\n          <article key={feature.title} className=\"landing-feature\">\n            <h3>{feature.title}</h3>\n            <p>{feature.description}</p>\n          </article>\n        ))}\n      </div>\n    </section>\n  );\n}\n\nexport default LandingAboutSection;\n"],"mappings":"AAAA,MAAO,CAAAA,KAAK,KAAM,OAAO,CACzB,MAAO,2BAA2B,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAEnC,KAAM,CAAAC,QAAQ,CAAG,CACf,CACEC,KAAK,CAAE,iBAAiB,CACxBC,WAAW,CAAE,0EACf,CAAC,CACD,CACED,KAAK,CAAE,kBAAkB,CACzBC,WAAW,CAAE,sFACf,CAAC,CACD,CACED,KAAK,CAAE,kBAAkB,CACzBC,WAAW,CAAE,4DACf,CAAC,CACF,CAED,QAAS,CAAAC,mBAAmBA,CAAA,CAAG,CAC7B,mBACEJ,KAAA,YAASK,SAAS,CAAC,eAAe,CAAAC,QAAA,eAChCN,KAAA,QAAKK,SAAS,CAAC,sBAAsB,CAAAC,QAAA,eACnCN,KAAA,QAAKK,SAAS,CAAC,qBAAqB,CAAAC,QAAA,eAClCR,IAAA,OAAAQ,QAAA,CAAI,mDAAS,CAAI,CAAC,cAClBR,IAAA,MAAAQ,QAAA,CAAG,mhCAIH,CAAG,CAAC,EACD,CAAC,cAENR,IAAA,QAAKO,SAAS,CAAC,2BAA2B,CAAAC,QAAA,cACxCR,IAAA,QAAKS,GAAG,CAAC,mBAAmB,CAACC,GAAG,CAAC,sHAAuB,CAAE,CAAC,CACxD,CAAC,EACH,CAAC,cAENR,KAAA,QAAKK,SAAS,CAAC,sBAAsB,CAAAC,QAAA,eACnCR,IAAA,QAAKO,SAAS,CAAC,sBAAsB,CAAAC,QAAA,cACnCR,IAAA,QAAKS,GAAG,CAAC,oBAAoB,CAACC,GAAG,CAAC,6FAAkB,CAAE,CAAC,CACpD,CAAC,cAENR,KAAA,QAAKK,SAAS,CAAC,2BAA2B,CAAAC,QAAA,eACxCR,IAAA,MAAAQ,QAAA,CAAG,s0BAIH,CAAG,CAAC,cACJR,IAAA,MAAAQ,QAAA,CAAG,y6BAIH,CAAG,CAAC,cACJR,IAAA,MAAAQ,QAAA,CAAG,4fAGH,CAAG,CAAC,EACD,CAAC,EACH,CAAC,cAENR,IAAA,QAAKO,SAAS,CAAC,kBAAkB,CAAAC,QAAA,CAC9BL,QAAQ,CAACQ,GAAG,CAAEC,OAAO,eACpBV,KAAA,YAA6BK,SAAS,CAAC,iBAAiB,CAAAC,QAAA,eACtDR,IAAA,OAAAQ,QAAA,CAAKI,OAAO,CAACR,KAAK,CAAK,CAAC,cACxBJ,IAAA,MAAAQ,QAAA,CAAII,OAAO,CAACP,WAAW,CAAI,CAAC,GAFhBO,OAAO,CAACR,KAGb,CACV,CAAC,CACC,CAAC,EACC,CAAC,CAEd,CAEA,cAAe,CAAAE,mBAAmB",