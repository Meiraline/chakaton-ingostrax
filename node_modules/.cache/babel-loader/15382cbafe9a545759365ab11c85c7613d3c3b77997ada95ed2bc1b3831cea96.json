E__*/_jsx(\"h4\",{children:\"\\u041A\\u043E\\u043D\\u0442\\u0430\\u043A\\u0442\\u044B\"}),/*#__PURE__*/_jsx(Link,{to:\"/contacts\",children:\"\\u0421\\u0432\\u044F\\u0437\\u0430\\u0442\\u044C\\u0441\\u044F \\u0441 \\u043D\\u0430\\u043C\\u0438\"}),/*#__PURE__*/_jsx(\"a\",{href:\"tel:+79954990250\",children:\"+7 (995) 499-02-50\"}),/*#__PURE__*/_jsx(\"a\",{href:\"mailto:ma.sarycheva2005@gmail.com\",children:\"ma.sarycheva2005@gmail.com\"})]})]})]})]})});}export default MainPage;","map":{"version":3,"names":["React","Link","Layout","Button","jsx","_jsx","jsxs","_jsxs","previewArticles","id","title","excerpt","image","MainPage","children","className","to","src","alt","variant","map","article","href"],"sources":["C:/My-Projact/chakaton-ingostrax/src/pages/main.js"],"sourcesContent":["import React from 'react';\nimport { Link } from 'react-router-dom';\nimport Layout from '../components/4_unity/Layout';\nimport Button from '../components/1_atoms/Button';\nimport './MainPage.css';\n\nconst previewArticles = [\n  {\n    id: 1,\n    title: 'Страхование жизни',\n    excerpt: 'Коротко и понятно о том, зачем нужна страховка жизни и как она помогает семье.',\n    image: '/png/blog.png',\n  },\n  {\n    id: 2,\n    title: 'Страхование имущества',\n    excerpt: 'Разбираем, как работает защита дома, квартиры, техники и других важных вещей.',\n    image: '/png/1_blok.png',\n  },\n  {\n    id: 3,\n    title: 'Страхование путешествий',\n    excerpt: 'Простое объяснение, почему страховка в поездке помогает избежать лишних рисков и расходов.',\n    image: '/png/2_blok.png',\n  },\n];\n\nfunction MainPage() {\n  return (\n    <Layout>\n      <div className=\"landing-page\">\n        <header className=\"landing-header\">\n          <div className=\"landing-header__brand\">\n            <Link to=\"/\" className=\"landing-logo\" aria-label=\"InsureKids\">\n              <img src=\"/logo.svg\" alt=\"InsureKids\" />\n            </Link>\n            <nav className=\"landing-nav\">\n              <Link to=\"/\">Главная</Link>\n              <Link to=\"/blog\">Блог</Link>\n              <Link to=\"/contacts\">Контакты</Link>\n            </nav>\n          </div>\n\n          <div className=\"landing-header__actions\">\n            <Link to=\"/register\">\n              <Button variant=\"secondary\" className=\"landing-header__button\">\n                Регистрация\n              </Button>\n            </Link>\n            <Link to=\"/login\">\n              <Button className=\"landing-header__button landing-header__button--login\">\n                Вход\n              </Button>\n            </Link>\n          </div>\n        </header>\n\n        <main className=\"landing-main\">\n          <section className=\"landing-hero\">\n            <div className=\"landing-hero__copy\">\n              <h1>Учись играя</h1>\n              <p className=\"landing-hero__subtitle\">\n                Интерактивная игра, где ребёнок изучает страхование через\n                приключения\n              </p>\n              <p className=\"landing-hero__text\">\n                Играй, принимай решения и изучай виды страхования вместе с\n                понятным блогом и живым игровым персонажем.\n              </p>\n              <div className=\"landing-hero__actions\">\n                <Link to=\"/blog\">\n                  <Button className=\"landing-hero__button landing-hero__button--blog\">\n                    Блог\n                  </Button>\n                </Link>\n                <Link to=\"/account\">\n                  <Button\n                    variant=\"secondary\"\n                    className=\"landing-hero__button landing-hero__button--play\"\n                  >\n                    Начать играть\n                  </Button>\n                </Link>\n              </div>\n            </div>\n\n            <div className=\"landing-hero__visual\">\n              <img src=\"/png/glavnaia.png\" alt=\"Обучение страхованию через игру\" />\n            </div>\n          </section>\n\n          <section className=\"landing-about\">\n            <div className=\"landing-about__intro\">\n              <div className=\"landing-about__text\">\n                <h2>О сервисе</h2>\n                <p>\n                  Этот сервис превращает знакомство со страхованием в понятное и\n                  увлекательное приключение. На сайте посетитель не просто\n                  читает о том, зачем нужны разные виды страховок, а учится\n                  понимать их через игру.\n                </p>\n              </div>\n              <div className=\"landing-about__image-card\">\n                <img\n                  src=\"/png/glavnaia.png\"\n                  alt=\"Ребёнок изучает виды страхования\"\n                />\n              </div>\n            </div>\n\n            <div className=\"landing-about__story\">\n              <div className=\"landing-about__image-card landing-about__image-card--large\">\n                <img\n                  src=\"/png/plaer_all.png\"\n                  alt=\"Персонаж проходит игровые события\"\n                />\n              </div>\n              <div className=\"landing-about__story-text\">\n                <p>\n                  Игровая часть делает обучение живым и интерактивным. У игрока\n                  есть персонаж со своими ресурсами — деньгами, здоровьем,\n                  счастьем, имуществом и страховыми полисами.\n                </p>\n                <p>\n                  На каждом ходу ему выпадают неожиданные события, хорошие и\n                  плохие, а дальше всё зависит от его решений: игрок общается с\n                  ИИ, выбирает, как поступить, и видит последствия своих\n                  действий.\n                </p>\n                <p>\n                  Так игрок постепенно понимает, как страховка помогает\n                  справляться с рисками и принимать решения.\n                </p>\n              </div>\n            </div>\n\n            <div className=\"landing-features\">\n              <article className=\"landing-feature\">\n                <h3>Понятный сервис</h3>\n                <p>\n                  Детям 7-14 лет удобно понимать важные темы через игру и яркие\n                  персонажи.\n                </p>\n              </article>\n              <article className=\"landing-feature\">\n                <h3>Страховки в игре</h3>\n                <p>\n                  Покупай страховки, изучай их характеристики и смотри, как они\n                  влияют на ход событий.\n                </p>\n              </article>\n              <article className=\"landing-feature\">\n                <h3>Блог с примерами</h3>\n                <p>\n                  Короткие статьи объясняют виды страхования простым языком.\n                </p>\n              </article>\n            </div>\n          </section>\n\n          <section className=\"landing-blog\">\n            <h2>Блог</h2>\n            <p className=\"landing-blog__lead\">\n              В нашем блоге собраны короткие статьи написанные простым языком:\n              они помогают разобраться, что такое страхование здоровья,\n              имущества, путешествий и других жизненных ситуаций без сложных\n              терминов и скучных объяснений.\n            </p>\n            <p className=\"landing-blog__lead\">\n              Пользователь может обращаться к этим статьям во время игры и тем\n              самым увеличивать свои шансы на успех в игре и в жизни.\n            </p>\n\n            <div className=\"landing-blog__grid\">\n              {previewArticles.map((article) => (\n                <Link\n                  key={article.id}\n                  to={`/blog/${article.id}`}\n                  className=\"landing-article\"\n                >\n                  <div className=\"landing-article__image\">\n                    <img src={article.image} alt={article.title} />\n                  </div>\n                  <div className=\"landing-article__body\">\n                    <h3>{article.title}</h3>\n                    <p>{article.excerpt}</p>\n                  </div>\n                </Link>\n              ))}\n            </div>\n\n            <div className=\"landing-blog__action\">\n              <Link to=\"/blog\">\n                <Button className=\"landing-blog__button\">Другие</Button>\n              </Link>\n            </div>\n          </section>\n        </main>\n\n        <footer className=\"landing-footer\">\n          <div className=\"landing-footer__brand\">\n            <img src=\"/logo.svg\" alt=\"InsureKids\" className=\"landing-footer__logo\" />\n            <p>*Сделано в рамках IT Purple Hack</p>\n          </div>\n\n          <div className=\"landing-footer__columns\">\n            <div className=\"landing-footer__column\">\n              <h4>Страницы</h4>\n              <Link to=\"/\">Главная</Link>\n              <Link to=\"/blog\">Блог</Link>\n              <Link to=\"/login\">Вход</Link>\n              <Link to=\"/register\">Регистрация</Link>\n            </div>\n\n            <div className=\"landing-footer__column\">\n              <h4>Контакты</h4>\n              <Link to=\"/contacts\">Связаться с нами</Link>\n              <a href=\"tel:+79954990250\">+7 (995) 499-02-50</a>\n              <a href=\"mailto:ma.sarycheva2005@gmail.com\">\n                ma.sarycheva2005@gmail.com\n              </a>\n            </div>\n          </div>\n        </footer>\n      </div>\n    </Layout>\n  );\n}\n\nexport default MainPage;\n"],"mappings":"AAAA,MAAO,CAAAA,KAAK,KAAM,OAAO,CACzB,OAASC,IAAI,KAAQ,kBAAkB,CACvC,MAAO,CAAAC,MAAM,KAAM,8BAA8B,CACjD,MAAO,CAAAC,MAAM,KAAM,8BAA8B,CACjD,MAAO,gBAAgB,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAExB,KAAM,CAAAC,eAAe,CAAG,CACtB,CACEC,EAAE,CAAE,CAAC,CACLC,KAAK,CAAE,mBAAmB,CAC1BC,OAAO,CAAE,gFAAgF,CACzFC,KAAK,CAAE,eACT,CAAC,CACD,CACEH,EAAE,CAAE,CAAC,CACLC,KAAK,CAAE,uBAAuB,CAC9BC,OAAO,CAAE,+EAA+E,CACxFC,KAAK,CAAE,iBACT,CAAC,CACD,CACEH